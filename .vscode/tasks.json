{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Compilar e Rodar Raylib Linux",
            "type": "shell",
            "command": "clang",
            "args": [
                "main.c",
                "player.c",
                "game.c",
                "inimigo.c",
                "-o",
                "main",
                "-lraylib",
                "-lGL",
                "-lm",
                "-lpthread",
                "-ldl",
                "-lrt",
                "-lX11",
                "&&",
                "./main"
            ],
            "options": {
                "shell": {
                    "executable": "/bin/bash",
                    "args": ["-c"]
                }
            },
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}